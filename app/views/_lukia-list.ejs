<section class="panel stack" id="lukia-section">
  <div class="toolbar">
    <h2>All Lukias</h2>
    <form method="get" action="/" class="sorter" id="sort-form">
      <label for="sort">Sort by</label>
      <select id="sort" name="sort">
        <% Object.entries(sortOptions).forEach(([key, option]) => { %>
          <% if (!(key === "unrated" && !currentUser)) { %>
            <option value="<%= key %>" <%= key === selectedSort ? "selected" : "" %>>
              <%= option.label %>
            </option>
          <% } %>
        <% }) %>
      </select>
      <label for="author">Author</label>
      <select id="author" name="author">
        <option value="">All authors</option>
        <% authors.forEach((author) => { %>
          <option
            value="<%= author.id %>"
            <%= Number(selectedAuthorId) === Number(author.id) ? "selected" : "" %>
          >
            <%= author.name %>
          </option>
        <% }) %>
      </select>
      <label for="age">Age</label>
      <select id="age" name="age">
        <% Object.entries(ageOptions).forEach(([key, option]) => { %>
          <option value="<%= key %>" <%= key === selectedAge ? "selected" : "" %>>
            <%= option.label %>
          </option>
        <% }) %>
      </select>
      <noscript><button type="submit">Apply</button></noscript>
    </form>
  </div>

  <p class="sort-status" aria-live="polite"></p>

  <% if (lukias.length === 0) { %>
    <p class="muted">No Lukias yet. Post the first one.</p>
  <% } %>

  <div class="lukia-list">
    <% lukias.forEach((lukia, index) => { %>
      <article class="lukia-card">
        <div class="rank-badge">#<%= index + 1 %></div>
        <div class="lukia-copy">
          <h3><a class="lukia-link" href="/lukias/<%= lukia.id %>"><%= lukia.phrase %></a></h3>
          <p>
            By <strong><%= lukia.author_name %></strong>
            on <%= new Date(lukia.created_at).toLocaleDateString("en-GB", { dateStyle: "medium" }) %>
          </p>
          <% if (currentUser && Number(currentUser.id) === Number(lukia.author_id)) { %>
            <form method="post" action="/lukias/<%= lukia.id %>/delete" class="delete-form">
              <input type="hidden" name="sort" value="<%= selectedSort %>" />
              <input type="hidden" name="author" value="<%= selectedAuthorId || "" %>" />
              <input type="hidden" name="age" value="<%= selectedAge %>" />
              <button type="submit" class="ghost delete-button">Delete</button>
              <p class="delete-status" aria-live="polite"></p>
            </form>
          <% } %>
          <p class="rating-summary">
            Average:
            <strong data-rating-summary-value><%= lukia.average_rating === null ? "Unrated" : `${lukia.average_rating} / 5` %></strong>
            <span data-rating-summary-count>
              <% if (lukia.rating_count > 0) { %>
                from <%= lukia.rating_count %> rating<%= lukia.rating_count === 1 ? "" : "s" %>
              <% } %>
            </span>
          </p>
        </div>

        <form method="post" action="/ratings" class="rating-form">
          <input type="hidden" name="lukia_id" value="<%= lukia.id %>" />
          <input type="hidden" name="sort" value="<%= selectedSort %>" />
          <input type="hidden" name="author" value="<%= selectedAuthorId || "" %>" />
          <input type="hidden" name="age" value="<%= selectedAge %>" />
          <label for="rating-<%= lukia.id %>">Your rating</label>
          <p class="rated-indicator">
            <% if (lukia.user_rating === null || lukia.user_rating === undefined) { %>
              You have not rated this yet.
            <% } else { %>
              You rated this <strong><%= lukia.user_rating %>/5</strong>.
            <% } %>
          </p>
          <div class="rating-row">
            <select id="rating-<%= lukia.id %>" name="rating">
              <% for (let i = 1; i <= 5; i += 1) { %>
                <option value="<%= i %>" <%= Number(lukia.user_rating) === i ? "selected" : "" %>>
                  <%= i %> star<%= i === 1 ? "" : "s" %>
                </option>
              <% } %>
            </select>
            <button type="submit">Save</button>
          </div>
          <p class="rating-status" aria-live="polite"></p>
        </form>
      </article>
    <% }) %>
  </div>
</section>
