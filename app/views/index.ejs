<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lukia Rank</title>
    <link rel="stylesheet" href="/styles.css" />
    <script src="/app.js" defer></script>
  </head>
  <body>
    <section class="hero-band">
      <div class="hero-shell">
        <div class="hero">
          <p class="eyebrow">Lukia Rank</p>
          <h1>Database of our best, worst, and most harrowing Lukias</h1>
          <p class="lede">
            Post new entries, rate them from 1 to 5 stars, and browse the archive by
            score, age, or author.
          </p>
        </div>
      </div>
    </section>

    <main class="shell">

      <% if (flashMessage) { %>
        <p class="flash success"><%= flashMessage %></p>
      <% } %>
      <% if (flashError) { %>
        <p class="flash error"><%= flashError %></p>
      <% } %>

      <section class="grid">
        <div class="panel stack" id="login-panel">
          <h2>Name Login</h2>
          <% if (currentUser) { %>
            <p class="login-copy">You are posting as <strong><%= currentUser.name %></strong>.</p>
            <form method="post" action="/logout">
              <button type="submit" class="ghost">Switch name</button>
            </form>
          <% } else { %>
            <form method="post" action="/login" class="stack" id="login-form">
              <label for="name">Your name</label>
              <input id="name" name="name" type="text" maxlength="40" placeholder="Name" required />
              <button type="submit">Enter</button>
            </form>
          <% } %>
          <p class="login-status" aria-live="polite"></p>
        </div>

        <div class="panel stack" id="post-panel">
          <h2>Post a Lukia</h2>
          <form method="post" action="/lukias" class="stack" id="post-form">
            <label for="phrase">Phrase</label>
            <input id="phrase" name="phrase" type="text" maxlength="140" placeholder="bowling ball" required />
            <p class="phrase-status" aria-live="polite"></p>
            <label for="created_at">Date</label>
            <input id="created_at" name="created_at" type="date" value="<%= defaultCreatedAt %>" />
            <button type="submit">Post Lukia</button>
          </form>
          <p class="post-status" aria-live="polite"></p>
          <p class="muted">You can type either “bowling ball” or the full “Lukia bowling ball”.</p>
        </div>
      </section>

      <%- include("_lukia-list") %>
    </main>
  </body>
  </html>
